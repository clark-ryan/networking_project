!  downstairs_sw2 – Switch Configuration

configure terminal

! --- Global Settings ---
no service timestamps log datetime msec
no service timestamps debug datetime msec
service password-encryption
hostname downstairs_sw2
enable secret 5 $1$mERr$tKAvQPi4nwql8vUTe8ogt/

! --- Spanning Tree ---
spanning-tree mode pvst
spanning-tree extend system-id

! --- Banner ---
banner motd ^C
Authorized Access Only.
^C

! --- Trunk Port ---
interface FastEthernet0/1
 switchport trunk native vlan 99
 switchport trunk allowed vlan 22
 switchport mode trunk

! --- Active Access Port ---
interface FastEthernet0/2
 switchport access vlan 22
 switchport mode access

! --- Unused Access Ports (Shutdown) ---
interface range FastEthernet0/3 - 24
 switchport access vlan 888
 switchport mode access
 shutdown

! --- Unused Gigabit Ports (Shutdown) ---
interface range GigabitEthernet0/1 - 2
 switchport access vlan 888
 switchport mode access
 shutdown

! --- Management SVI ---
interface Vlan1
 no ip address
 shutdown

! --- Console Line ---
line con 0
 password 7 08314D5D1A0E0A05165A5E57
 logging synchronous
 login
 exec-timeout 5 0

! --- VTY Lines ---
line vty 0 4
 no login
 transport input none
line vty 5 15
 no login
 transport input none

end
